# NovaCura Environment Configuration
# Copy this file to .env and fill in your values

# Authentication - Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Database Configuration
DATABASE_URL=postgresql://pharma:password@postgres:5432/pharmanexus
POSTGRES_PASSWORD=password

# Redis Configuration
REDIS_PASSWORD=redis123
CELERY_BROKER=redis://:redis123@localhost:6379/1
REDIS_URL=redis://:redis123@localhost:6379/0
SOCKETIO_MESSAGE_QUEUE=redis://:redis123@localhost:6379/0

# LLM Configuration (Upgrade 7)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Flower Monitoring
FLOWER_USER=admin
FLOWER_PASSWORD=flower123
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123

# Development Settings
FLASK_ENV=development
DEBUG=false

# ChEMBL Configuration
CHEMBL_CACHE_DIR=chembl_cache
CHEMBL_MAX_RECORDS=2000
CHEMBL_BINDING_TARGET=CHEMBL203
CHEMBL_BIOAVAIL_TARGET=CHEMBL25
CHEMBL_SOLUBILITY_TARGET=CHEMBL1907601
PUBCHEM_AID_LIST=743269,720709

# Model Configuration
MODEL_PATH=models/model.joblib
ENSEMBLE_PATH=models/ensemble.joblib
TA_MODELS_DIR=ta_models
MODEL_DRIFT_THRESHOLD=0.3
PREDICTION_DRIFT_WINDOW=500

# Security
SECRET_KEY=replace-with-64-char-random-secret-key-before-prod-2026
JWT_SECRET_KEY=replace-with-64-char-random-jwt-secret-before-prod-2026
AUTH_JWT_SECRET=replace-with-64-char-random-auth-jwt-secret-before-prod

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/novacura.log

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# API Configuration
API_RATE_LIMIT=60
API_RATE_WINDOW=3600

# Feature Flags
ENABLE_CHEMBL_INTEGRATION=true
ENABLE_SMILES_PIPELINE=true
ENABLE_THERAPEUTIC_MODELS=true
ENABLE_ACTIVE_LEARNING=true
ENABLE_LLM_ANALYST=true
ENABLE_GNN_MODEL=false
