{
  "id": null,
  "uid": "nexuscliniq-overview",
  "title": "NexusCliniQ ML Operations",
  "tags": ["nexuscliniq", "ml", "backend"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "p95 prediction latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(prediction_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 latency",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Predictions per minute by tier",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (result_tier) (rate(predictions_total[1m]))",
          "legendFormat": "{{result_tier}}",
          "refId": "A"
        }
      ],
      "options": {
        "stacking": "normal"
      }
    },
    {
      "id": 3,
      "title": "Model errors per hour",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(model_errors_total[1h])",
          "legendFormat": "errors/hour",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Active learning queue depth",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "active_learning_queue_depth",
          "legendFormat": "queue depth",
          "refId": "A"
        }
      ]
    }
  ]
}
